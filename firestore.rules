rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isHouseMember(houseId) {
      return isAuthenticated() &&
        request.auth.uid in 
        get(/databases/$(database)/documents/houses/$(houseId)).data.members;
    }

    // Perfiles: solo el propio usuario
    match /users/{userId} {
      allow read, write: if isAuthenticated() 
        && request.auth.uid == userId;
    }

    match /houses/{houseId} {
      // Crear casa: solo si te incluís como miembro
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.members;

      // Leer: solo miembros
      allow read: if isHouseMember(houseId);

      // Actualizar: solo miembros (para unirse con código)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members;

      // Nunca borrar una casa
      allow delete: if false;

      match /products/{productId} {
        allow read, write: if isHouseMember(houseId);
      }
      match /purchases/{purchaseId} {
        allow read, write: if isHouseMember(houseId);
        match /items/{itemId} {
          allow read, write: if isHouseMember(houseId);
        }
      }
      match /balances/{balanceId} {
        allow read, write: if isHouseMember(houseId);
      }
      match /notifications/{notificationId} {
        allow read, write: if isHouseMember(houseId);
      }
    }
  }
}